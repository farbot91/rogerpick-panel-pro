{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "telegram-socks",
      "listen": "127.0.0.1",
      "port": 9050,
      "protocol": "socks",
      "settings": {
        "auth": "noauth",
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": [
          "telegram-socks"
        ],
        "outboundTag": "direct"
      }
    ]
  }
}
